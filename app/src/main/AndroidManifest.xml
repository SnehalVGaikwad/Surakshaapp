<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.suraksha.surakshaapp">

    <!-- Internet -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Emergency Calls -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- SMS -->
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-feature android:name="android.hardware.telephony" android:required="false"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SurakshaApp">

        <!-- Splash Activity (Launcher) -->
        <activity
            android:name=".Activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".Activities.LoginActivity"
            android:exported="false" />

        <!-- Registration Activity -->
        <activity
            android:name=".Activities.RegistrationActivity"
            android:exported="false" />

        <!-- Emergency Contact Activity -->
        <activity
            android:name=".Activities.EmergencyContactActivity"
            android:exported="false" />

        <!-- Success Activity -->
        <activity
            android:name=".Activities.SuccessActivity"
            android:exported="false" />

        <!-- Home Activity -->
        <activity
            android:name=".Activities.HomeActivity"
            android:exported="false" />

        <!-- Permission Blocked Activity -->
        <activity
            android:name=".Activities.PermissionBlockedActivity"
            android:exported="false" />

        <!-- Main Activity (deprecated, but kept) -->
        <activity
            android:name=".Activities.MainActivity"
            android:exported="false" />

    </application>

</manifest>
