<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_suraksha">

    <TextView
        android:id="@+id/tv_final_warning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SOS message will be sent to your emergency contacts in 30 seconds"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/accent_pink_dark"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tv_final_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="30"
        android:textSize="72sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btn_cancel_sos"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Cancel SOS"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:background="@drawable/rounded_btn_bg"/>

</LinearLayout>