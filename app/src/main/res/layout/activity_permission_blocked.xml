<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_suraksha"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- Warning Icon -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/suraksha_logo"
        android:contentDescription="Warning"
        android:layout_marginBottom="32dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Permissions Required"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/accent_pink_dark"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Suraksha needs the following permissions to function:\n\n• Phone Calls (Emergency numbers)\n• SMS (Alert messages)\n• Location (Emergency location)\n• Notifications (Alert alerts)\n\nPlease grant these permissions to continue."
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="48dp" />

    <!-- Retry Button -->
    <Button
        android:id="@+id/btn_retry_permissions"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Grant Permissions"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/rounded_btn_bg" />

    <!-- Info Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You can also grant permissions from Settings."
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="24dp"
        android:gravity="center" />

</LinearLayout>
